# ミニ四駆シミュレーター 環境変数（サンプル値。本番運用時は必ず書き換えること）
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ログインボーナス付与額（en）
LOGIN_BONUS_EN=1000

# ホスト結果報告タイムアウト（秒）：6-1参照
RACE_REPORT_TIMEOUT_SEC=120

# 部屋自動削除の経過時間しきい値（時間）：9-1参照
ROOM_STALE_HOURS=6
