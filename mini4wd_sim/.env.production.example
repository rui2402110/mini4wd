# .env.production ── 本番環境用の環境変数テンプレート（デプロイ要件2）
#
# 使い方:
#   1. このファイルを「.env」という名前でEC2サーバー上のプロジェクトルートに配置する
#      （ファイル名を必ず .env に変更すること。compose.yaml が env_file: .env を参照している）。
#   2. 下記の値（特に DJANGO_SECRET_KEY）を実際の本番用の値に書き換える。
#   3. このファイルはGitやZIPに含めて配布しない（.gitignoreに.envを入れておくこと）。

# ── Django基本設定 ──
# SECRET_KEYは以下のコマンドで生成できる（EC2上でもローカルでもよい）:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=OBBqc8zEmhY8zz_PI7TCp6NzM9pS_zfnmFC5g8PMgVvECWrpRv4EGaP1VsieBEZv8t4
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=mini4wdsim.duckdns.org,3.218.32.232

# NginxがHTTPSで終端し、X-Forwarded-Protoヘッダーを付与する構成であることをDjangoに伝える
DJANGO_BEHIND_HTTPS_PROXY=True
DJANGO_CSRF_TRUSTED_ORIGINS=https://mini4wdsim.duckdns.org

# ── Redis（Docker Compose内のサービス名で接続する。値はcompose.yaml側で上書きされるため
#     通常はこのままで問題ないが、ローカルでこの.envを流用する場合のために残してある） ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── ログインボーナス付与額（en） ──
LOGIN_BONUS_EN=1000

# ── ホスト結果報告タイムアウト（秒）：6-1参照 ──
RACE_REPORT_TIMEOUT_SEC=120

# ── 部屋自動削除の経過時間しきい値（時間）：9-1参照 ──
ROOM_STALE_HOURS=6
